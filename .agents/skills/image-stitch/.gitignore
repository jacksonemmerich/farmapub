# Git ignore for image-stitch project

# Ignore everything in input/ and output/ except .gitkeep
input/*
!input/.gitkeep
output/*
!output/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
.env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
